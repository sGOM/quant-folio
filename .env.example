# ─────────────────────────────────────────────────────────────
# QuantFolio 환경변수 예시 — 복사해서 .env 로 사용하세요.
#   cp .env.example .env
# ─────────────────────────────────────────────────────────────

# --- 실행 환경 ---
# dev: 누락된 시크릿을 임시 생성해 부팅 허용(로컬 편의)
# prod: 필수 시크릿 누락·약한 키·비보안 쿠키면 부팅 거부
APP_ENV=dev

# --- Database (PostgreSQL + TimescaleDB) ---
POSTGRES_USER=quant
POSTGRES_PASSWORD=quant
POSTGRES_DB=quant
# 컨테이너 내부에서는 host=db, 로컬 실행 시 host=localhost
DATABASE_URL=postgresql+asyncpg://quant:quant@db:5432/quant

# --- Redis (pub/sub · 큐 · 분산 락) ---
REDIS_URL=redis://redis:6379/0

# --- 보안 ---
# 🔐 마스터 키(SECRET_KEY, CREDENTIAL_ENC_KEY)는 시크릿 파일로 두는 것을 권장한다.
#    docker compose: secrets/*.txt 를 *_FILE 로 주입(secrets/README.md 참고).
#    아래 평문 변수는 로컬 비-Docker 실행 편의용 폴백이며, 운영에선 비워 두세요.
#    설정 로더는 `<FIELD>_FILE` 가 가리키는 파일을 평문 env 보다 우선 사용한다.
#  - SECRET_KEY: openssl rand -hex 32
#  - CREDENTIAL_ENC_KEY: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
SECRET_KEY=
SECRET_KEY_FILE=/run/secrets/secret_key
CREDENTIAL_ENC_KEY=
CREDENTIAL_ENC_KEY_FILE=/run/secrets/credential_enc_key

# --- 인증(서버측 세션) ---
# 로그인 세션은 Redis 에 저장되고, 쿠키에는 불투명 세션 ID 만 담긴다.
# 활동이 있으면 TTL 이 슬라이딩 갱신된다(분 단위, 기본 14일).
SESSION_TTL_MINUTES=20160

# --- 인증 쿠키 ---
# 운영(HTTPS)에서는 COOKIE_SECURE=true 필수.
# 단일 출처(proxy) 운용이면 COOKIE_SAMESITE=lax 로 충분하다.
COOKIE_SECURE=false
COOKIE_SAMESITE=lax
# COOKIE_DOMAIN=

# --- 한국투자증권 KIS API ---
# 기본값은 모의투자(vts). 실전 전환 시에만 prod 로 변경.
KIS_ENV=vts
KIS_BASE_URL_VTS=https://openapivts.koreainvestment.com:29443
KIS_BASE_URL_PROD=https://openapi.koreainvestment.com:9443
# 실시간 시세는 TLS(wss) 로 연결한다 — 평문 ws 금지.
KIS_WS_URL_VTS=wss://ops.koreainvestment.com:31000
KIS_WS_URL_PROD=wss://ops.koreainvestment.com:21000
# 🔐 개인 운영 폴백 자격증명(웹 등록 없이 매매)은 평문 .env 대신 시크릿 파일로:
#    secrets/kis_app_key.txt, secrets/kis_app_secret.txt → *_FILE 로 주입.
#    (멀티 유저는 비워 두고 사용자별 등록 API 사용)
KIS_APP_KEY=
KIS_APP_KEY_FILE=/run/secrets/kis_app_key
KIS_APP_SECRET=
KIS_APP_SECRET_FILE=/run/secrets/kis_app_secret
KIS_ACCOUNT_NO=   # 'CANO-PRDT' 형식 (예: 50012345-01). 계좌번호는 비밀 아님.

# --- 토스증권 Open API (선택) ---
# 사용할 증권사는 사용자별(User.broker)로 결정된다. 자격증명은 DB 등록값을
# 우선하고, 없으면 아래 폴백을 사용한다(client_id/secret 은 시크릿 파일로).
# 토스는 단일 도메인·REST 전용(WS 미지원)·모의투자 환경 없음(항상 실거래).
TOSS_BASE_URL=https://openapi.tossinvest.com
TOSS_APP_KEY=
TOSS_APP_KEY_FILE=/run/secrets/toss_app_key
TOSS_APP_SECRET=
TOSS_APP_SECRET_FILE=/run/secrets/toss_app_secret
TOSS_ACCOUNT_NO=   # =accountSeq. 비밀 아님.

# --- CORS / Frontend ---
# 단일 출처(proxy) 운용에서는 브라우저 요청이 같은 출처라 CORS 가 트리거되지
# 않는다. 8000 포트로 직접 접속하는 로컬 개발 시에만 의미가 있다.
FRONTEND_ORIGIN=http://localhost:3000

# --- Frontend (Next.js) ---
# 비워 두면 프론트가 상대경로로 API/WS 를 호출한다(= 접속한 출처 그대로).
# proxy 를 통해 접속하는 표준 운용에서는 반드시 비워 둔다. 폰이 Tailscale
# 머신명/IP 어느 주소로 들어와도 그대로 동작하고 재빌드가 필요 없다.
# (프론트만 단독으로 8000 백엔드에 붙여 개발할 때만 http://localhost:8000 지정)
NEXT_PUBLIC_API_BASE_URL=

# --- 외부 접속(proxy) ---
# 폰/외부에서 접속할 단일 진입 포트. 예) http://<Tailscale-머신명>:8080
# 80 이 비어 있으면 80 으로 바꿔 포트 없이 접속할 수도 있다.
APP_PORT=8080
